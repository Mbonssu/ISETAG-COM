# ============================================================
# Configuration des adresses du backend (voir services/apiBaseUrl.js)
# ============================================================
#
# Copiez ce fichier en ".env" (à la racine du projet, à côté de
# package.json) et remplissez les vraies valeurs. NE JAMAIS committer
# le fichier ".env" lui-même dans Git (seul ".env.example" doit l'être) :
# ces adresses changent d'un poste/réseau à l'autre.
#
# Comportement : l'app essaie TOUJOURS l'URL ngrok en premier. Si elle
# ne répond pas (tunnel fermé, pas d'accès internet...), elle bascule
# automatiquement sur l'adresse locale statique, tant que l'utilisateur
# est sur le même réseau local que le serveur Django.
#
# Après un redémarrage de React (npm start / build), ces variables sont
# figées au build — il faut relancer après toute modification du .env.

# URL publique ngrok qui pointe vers le serveur Django (priorité 1)

REACT_APP_NGROK_URL=https://votre-tunnel.ngrok-free.dev

#  Si votre Django n'écoute qu'en HTTPS (cas fréquent en local avec un
# certificat auto-signé), cette adresse DOIT être en https://, pas http://.
# De plus, un certificat auto-signé sera refusé par le navigateur tant que
# vous n'avez pas ouvert cette URL manuellement une fois dans un onglet et
# cliqué sur "Continuer quand même" / "Accepter le risque" — fetch() ne
# peut pas contourner ça automatiquement, c'est une protection navigateur.
# Adresse IP locale statique du serveur Django sur le réseau local (priorité 2, secours)

REACT_APP_LOCAL_URL=https://192.168.30.33:8000