# Copie ce fichier en .env et remplis les valeurs reelles.
# settings.py lit ces variables via os.environ.get(...) avec des valeurs
# par defaut identiques a l'ancien comportement, donc l'app tourne meme
# sans .env -- mais NE PAS deployer en prod sans les definir.

DJANGO_SECRET_KEY=change-moi-en-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*

DB_NAME=ISETAG-COM
DB_USER=postgres
DB_PASSWORD=change-moi
DB_HOST=localhost
DB_PORT=5432

# URLs autorisees a appeler l'API (frontend Vite/React), separees par des virgules
DJANGO_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
